# =============================================================================
# BCG X Analytics Accelerator — .gitignore
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Build / Distribution ──────────────────────────────────────────────────────
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.env
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# Keep the example — that's safe to commit
!.env.example

# ── Testing / Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml
pytest.ini.bak

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── Linting ───────────────────────────────────────────────────────────────────
.ruff_cache/

# ── MLflow artefacts ──────────────────────────────────────────────────────────
mlruns/
!mlruns/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/*.log
logs/*.log.zip
!logs/.gitkeep

# ── Data — keep .gitkeep, exclude everything else ─────────────────────────────
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/features/*
!data/features/.gitkeep
data/outputs/*
!data/outputs/.gitkeep

# ── Model artefacts ───────────────────────────────────────────────────────────
*.pkl
*.joblib
*.h5
*.hdf5
*.onnx
*.pt
*.pth

# ── Jupyter notebooks ─────────────────────────────────────────────────────────
notebooks/.ipynb_checkpoints/
.ipynb_checkpoints/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editors ───────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.spyderproject.cfg
.spyproject/

# ── Docker ────────────────────────────────────────────────────────────────────
docker/.env

# ── Secrets / credentials ─────────────────────────────────────────────────────
*.pem
*.key
credentials.json
service_account.json
